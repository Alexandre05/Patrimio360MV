{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["administrador", "prefeito", "responsavel", "vistoriador"] },
        "createdAt": { "type": "integer" }
      },
      "required": ["userId", "name", "email", "role"]
    },
    "Location": {
      "title": "Location",
      "description": "A physical location or sector being inspected",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Inspection": {
      "title": "Inspection",
      "description": "An inspection event at a location",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "locationId": { "type": "string" },
        "date": { "type": "integer" },
        "status": { "type": "string", "enum": ["em_andamento", "concluida", "finalizada"] },
        "concludedBy": { "type": "string" },
        "concludedAt": { "type": "integer" },
        "finalizedBy": { "type": "string" },
        "finalizedAt": { "type": "integer" },
        "qrCodeData": { "type": "string" }
      },
      "required": ["id", "locationId", "date", "status"]
    },
    "Asset": {
      "title": "Asset",
      "description": "An item registered during an inspection",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "inspectionId": { "type": "string" },
        "name": { "type": "string" },
        "patrimonyNumber": { "type": "string" },
        "condition": { "type": "string", "enum": ["bom", "regular", "danificado", "inservivel"] },
        "observations": { "type": "string" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "integer" },
        "hash": { "type": "string" }
      },
      "required": ["id", "inspectionId", "name", "condition", "createdBy", "createdAt"]
    },
    "SectorConcludedInspection": {
      "title": "Sector Concluded Inspection",
      "description": "Signed responsibility term for a sector",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "locationName": { "type": "string" },
        "inspectionId": { "type": "string" },
        "assetIds": { "type": "array", "items": { "type": "string" } },
        "responsibleName": { "type": "string" },
        "signatureBase64": { "type": "string" },
        "signedAt": { "type": "integer" },
        "signedByUser": { "type": "string" }
      },
      "required": ["id", "locationName", "inspectionId", "assetIds", "responsibleName", "signatureBase64", "signedAt", "signedByUser"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Global user profiles"
    },
    "/locations/{locationId}": {
      "schema": "Location",
      "description": "Registered locations"
    },
    "/inspections/{inspectionId}": {
      "schema": "Inspection",
      "description": "Inspection records"
    },
    "/assets/{assetId}": {
      "schema": "Asset",
      "description": "Assets registered across all inspections"
    },
    "/sector_inspections/{id}": {
      "schema": "SectorConcludedInspection",
      "description": "Concluded sector inspections with signatures"
    }
  }
}
