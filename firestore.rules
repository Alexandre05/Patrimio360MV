rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow test connection
    match /test/connection {
      allow read: if true;
    }

    // 1. Primitives & Helpers
    function isSignedIn() { return request.auth != null; }
    function isRegistered() { return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isVerified() { return isRegistered(); } // Strictly require the user to be in the "users" collection
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Helper for Admin Check
    function isAdmin() { 
      // User is an admin if they are the primary owner OR if they have the 'administrador' role (safe get)
      return isSignedIn() && (
        request.auth.token.email == 'henri199@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'administrador')
      ); 
    }

    // 2. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.userId == userId &&
               data.name is string && data.name.size() <= 100 &&
               data.email is string && data.email.size() <= 100;
      }

      allow read: if true;
      // Only Admins can create new users, effectively blocking any random Google Login from generating an account!
      allow create: if isSignedIn() && isValidUser(incoming()) && isAdmin();
      
      // Users can update their own info, but CANNOT elevate their role unless they are an admin
      allow update: if isVerified() && isValidUser(incoming()) && (
        isAdmin() || 
        (request.auth.uid == userId && incoming().role == existing().role)
      );
      
      allow delete: if isAdmin();
    }

    // 3. Locations Collection
    match /locations/{locationId} {
      function isValidLocation(data) {
        return isValidId(data.id) &&
               data.name is string && data.name.size() <= 150 &&
               data.description is string && data.description.size() <= 500;
       }

      allow get, list: if true; 
      allow write: if isVerified(); // Ideally restricted to managers in future
      allow delete: if isVerified();
    }

    // 4. Inspections Collection
    match /inspections/{inspectionId} {
      function isValidInspection(data) {
        return isValidId(data.id) &&
               data.locationId is string &&
               data.status in ['em_andamento', 'concluida', 'finalizada'];
      }

      allow get: if isSignedIn();
      allow get: if resource.data.status == 'finalizada';
      allow list: if isSignedIn();
      allow list: if resource.data.status == 'finalizada'; 
      
      allow create: if isVerified() && isValidInspection(incoming());
      allow update: if isVerified() && isValidInspection(incoming());
      allow delete: if isVerified();
    }

    // 5. Assets Collection
    match /assets/{assetId} {
      function isValidAsset(data) {
        return isValidId(data.id) &&
               data.name is string && data.name.size() <= 150 &&
               data.inspectionId is string &&
               data.condition in ['novo', 'bom', 'regular', 'ruim', 'inservivel'];
      }

      allow get, list: if isSignedIn();
      allow get: if get(/databases/$(database)/documents/inspections/$(resource.data.inspectionId)).data.status == 'finalizada';
      // For public list queries on assets, the client MUST filter by inspectionId.
      allow list: if get(/databases/$(database)/documents/inspections/$(resource.data.inspectionId)).data.status == 'finalizada';
      
      allow write: if isVerified() && isValidAsset(incoming());
      allow delete: if isVerified();
    }

    // Admins Collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable through console
    }
  }
}
