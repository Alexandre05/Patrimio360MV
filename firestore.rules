rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow test connection
    match /test/connection {
      allow read: if true;
    }

    // 1. Primitives & Helpers
    function isSignedIn() { return request.auth != null; }
    function isRegistered() { return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isVerified() { return isRegistered(); } // Strictly require the user to be in the "users" collection
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Helper for Admin Check
    function isAdmin() { 
      // User is an admin if they exist in the 'admins' collection
      // This is the most secure way to manage master privileges.
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Helper for Role Check
    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isSystemAdmin() {
      return isAdmin() || hasRole('administrador');
    }

    // 2. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.userId == userId &&
               data.name is string && data.name.size() <= 100 &&
               data.email is string && data.email.size() <= 100;
      }

      allow read: if isSignedIn(); // Restricted to signed in users
      
      // Permission to create a user:
      // 1. You are a System Admin (in admins collection or has role administrador)
      // 2. OR this is the very first user (bootstrapping)
      // For bootstrapping, we use a sentinel document /users/_config
      allow create: if isSignedIn() && isValidUser(incoming()) && (
        isSystemAdmin() || 
        !exists(/databases/$(database)/documents/users/_config)
      );
      
      // Users can update their own info, but CANNOT elevate their role unless they are an admin
      allow update: if isVerified() && isValidUser(incoming()) && (
        isSystemAdmin() || 
        (request.auth.uid == userId && incoming().role == existing().role)
      );
      
      allow delete: if isSystemAdmin();
    }

    // Config Sentinel
    match /users/_config {
      allow read: if true;
      allow create: if isSignedIn() && !exists(/databases/$(database)/documents/users/_config);
      allow update, delete: if isSystemAdmin();
    }

    // 3. Locations Collection
    match /locations/{locationId} {
      function isValidLocation(data) {
        return isValidId(data.id) &&
               data.name is string && data.name.size() <= 150 &&
               data.description is string && data.description.size() <= 500;
       }

      allow get, list: if true; 
      allow write: if isVerified(); // Ideally restricted to managers in future
      allow delete: if isVerified();
    }

    // 4. Inspections Collection
    match /inspections/{inspectionId} {
      function isValidInspection(data) {
        return isValidId(data.id) &&
               data.locationId is string &&
               data.status in ['em_andamento', 'concluida', 'finalizada'];
      }

      allow get: if isSignedIn();
      allow get: if resource.data.status == 'finalizada';
      allow list: if isSignedIn();
      allow list: if resource.data.status == 'finalizada'; 
      
      allow create: if isVerified() && isValidInspection(incoming());
      allow update: if isVerified() && isValidInspection(incoming());
      allow delete: if isVerified();
    }

    // 5. Assets Collection
    match /assets/{assetId} {
      function isValidAsset(data) {
        return isValidId(data.id) &&
               data.name is string && data.name.size() <= 150 &&
               data.inspectionId is string &&
               data.condition in ['novo', 'bom', 'regular', 'ruim', 'inservivel'] &&
               (data.get('isPublic', false) is bool);
      }

      allow get, list: if isSignedIn();
      allow get, list: if resource.data.isPublic == true;
      
      allow write: if isVerified() && isValidAsset(incoming());
      allow delete: if isVerified();
    }

    // 6. Sector Inspections
    match /sector_inspections/{id} {
      function isValidSectorInspection(data) {
        return isValidId(data.id) &&
               data.locationName is string && data.locationName.size() <= 200 &&
               data.inspectionId is string &&
               data.assetIds is list && data.assetIds.size() > 0 &&
               data.responsibleName is string && data.responsibleName.size() <= 150 &&
               data.signatureBase64 is string &&
               data.signedAt is int &&
               data.signedByUser == request.auth.uid;
      }

      allow get, list: if isSignedIn();
      allow create: if isVerified() && isValidSectorInspection(incoming());
      allow update, delete: if isSystemAdmin();
    }

    // Admins Collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable through console
    }
  }
}
