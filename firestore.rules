rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitives & Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); } // Relaxed verified check for Google Auth
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Helper for Admin Check
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    // 2. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.userId == userId &&
               data.name is string && data.name.size() <= 100 &&
               data.email is string && data.email.size() <= 100;
      }

      allow read: if true;
      allow create: if isVerified() && isValidUser(incoming());
      allow update: if isVerified() && (request.auth.uid == userId || isAdmin()) && isValidUser(incoming());
      allow delete: if isAdmin();
    }

    // 3. Locations Collection
    match /locations/{locationId} {
      function isValidLocation(data) {
        return isValidId(data.id) &&
               data.name is string && data.name.size() <= 150 &&
               data.description is string && data.description.size() <= 500;
       }

      allow get: if true; // Public read for QR scan
      allow list: if isSignedIn();
      allow write: if isVerified(); // Ideally restricted to managers in future
      allow delete: if isVerified();
    }

    // 4. Inspections Collection
    match /inspections/{inspectionId} {
      function isValidInspection(data) {
        return isValidId(data.id) &&
               data.locationId is string &&
               data.status in ['em_andamento', 'concluida', 'finalizada'];
      }

      allow get: if resource.data.status == 'finalizada' || isVerified();
      allow list: if isVerified(); 
      allow create: if isVerified() && isValidInspection(incoming());
      allow update: if isVerified() && isValidInspection(incoming());
      allow delete: if isAdmin();
    }

    // 5. Assets Collection
    match /assets/{assetId} {
      function isValidAsset(data) {
        return isValidId(data.id) &&
               data.name is string && data.name.size() <= 150 &&
               data.inspectionId is string &&
               data.condition in ['novo', 'bom', 'regular', 'ruim', 'inservivel'];
      }

      // Helper to check if parent inspection is finalized
      function isInspectionFinalized(id) {
        return get(/databases/$(database)/documents/inspections/$(id)).data.status == 'finalizada';
      }

      allow get, list: if isVerified() || isInspectionFinalized(resource.data.inspectionId);
      
      allow write: if isVerified() && isValidAsset(incoming());
    }
  }
}
